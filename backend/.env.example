PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/majic_automation

ZYTE_API_KEY=
ZYTE_PROXY_SERVER=http://api.zyte.com:8011
ZYTE_PROXY_PASSWORD=
ZYTE_PROXY_USERNAME_TEMPLATE={apiKey}
ZYTE_PROXY_ENABLED=false
ZYTE_EXTRACT_URL=https://api.zyte.com/v1/extract
ZYTE_REQUEST_TIMEOUT_MS=60000

# Inbound email OTP receiver
MAIL_DOMAIN=mydomain.com
MAIL_RECEIVE_MODE=webhook
OTP_ALIAS_LOCAL_PART=otp
OTP_SESSION_EXPIRE_MINUTES=10

# Comma-separated requesterId:apiKey pairs.
# Example request auth header: Authorization: Bearer replace-with-long-random-key
OTP_REQUESTER_API_KEYS=requester_1:replace-with-long-random-key

# Required for POST /api/mail/inbound webhooks.
INBOUND_MAIL_WEBHOOK_SECRET=replace-with-long-random-webhook-secret

# Required only when MAIL_RECEIVE_MODE=imap.
IMAP_HOST=mail.mydomain.com
IMAP_PORT=993
IMAP_USER=otp@mydomain.com
IMAP_PASSWORD=replace-with-mailbox-password
IMAP_SECURE=true
IMAP_POLL_INTERVAL_MS=30000
IMAP_ARCHIVE_FOLDER=
IMAP_MAX_MESSAGES_PER_POLL=10

# Optional mail server API.
MAIL_SERVER_API_BASE_URL=https://mail.example.com/api/v1
MAIL_SERVER_API_TOKEN=replace-with-mail-server-api-token
MAIL_SERVER_API_AUTH_HEADER=Authorization
